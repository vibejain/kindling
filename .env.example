# Copy to .env and fill in. Never commit .env.

APP_SECRET=change-me-to-a-long-random-string
APP_BASE_URL=http://127.0.0.1:8787
HOST=127.0.0.1
PORT=8787

# Dashboard login (prefer AUTH_PASSWORD_HASH; AUTH_PASSWORD is hashed on first boot)
AUTH_USERNAME=admin
AUTH_PASSWORD=
AUTH_PASSWORD_HASH=
SESSION_DAYS=14

# Web Push (VAPID). Generate once and keep private.
# python -c "from cryptography.hazmat.primitives.asymmetric import ec; from cryptography.hazmat.primitives import serialization; import base64; k=ec.generate_private_key(ec.SECP256R1()); print('VAPID_PRIVATE_KEY='+base64.urlsafe_b64encode(k.private_numbers().private_value.to_bytes(32,'big')).rstrip(b'=').decode()); print('VAPID_PUBLIC_KEY='+base64.urlsafe_b64encode(k.public_key().public_bytes(serialization.Encoding.X962, serialization.PublicFormat.UncompressedPoint)).rstrip(b'=').decode())"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# Type: Web application
# Redirect URI: https://kindling.example.com/auth/gmail/callback  (production)
#               http://127.0.0.1:8787/auth/gmail/callback       (local)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Content engine (LLM-free Node package under ./content-engine)
# CONTENT_ENGINE=0 disables; otherwise used when scripts/warm-next.ts exists
# CONTENT_ENGINE=1
# CONTENT_ENGINE_DIR=./content-engine
# CONTENT_ENGINE_TIMEOUT_SEC=45
# DATABASE_URL=postgres://content_engine:content_engine@127.0.0.1:5432/content_engine
# CONTENT_ENGINE_USE_LLM must stay unset/0
