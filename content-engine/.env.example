# Default matches local Homebrew Postgres. For Docker Compose use port 5433.
DATABASE_URL=postgres://content_engine:content_engine@127.0.0.1:5432/content_engine

# Content engine is LLM-free by default (local composition engine).
# Optional / dead path - only used when CONTENT_ENGINE_USE_LLM=1:
# CONTENT_ENGINE_USE_LLM=1
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-haiku-latest
